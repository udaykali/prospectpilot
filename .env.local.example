# ProspectPilot Environment Variables
# Copy this file to .env.local after deployment and fill in your values

# Supabase (get these from https://supabase.com dashboard > Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Gemini API (for AI outreach messages)
# Get a free API key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key

# Your app URL (your Vercel domain after deployment)
NEXT_PUBLIC_APP_URL=https://prospectpilot-xxx.vercel.app
